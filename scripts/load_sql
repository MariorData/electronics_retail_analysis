CREATE OR ALTER PROCEDURE load_tables AS
BEGIN
    BEGIN TRY
        TRUNCATE TABLE stg_dimcustomer;

		BULK INSERT stg_dimcustomer
		FROM 'C:\SQL_projects\global_Electronics_retailer\Customers.csv'
		WITH (
			FIRSTROW = 2,
			FIELDTERMINATOR = ',',
			TABLOCK
		);
		TRUNCATE TABLE dimcustomer
		INSERT INTO dimcustomer (
			CustomerKey,
			Gender,
			Name,
			City,
			StateCode,
			State,
			ZipCode,
			Country,
			Continent,
			Birthday
		)
		SELECT
			CustomerKey,
			Gender,
			Name,
			City,
			StateCode,
			State,
			ZipCode,
			Country,
			Continent,
			TRY_CONVERT(date, Birthday, 101)
		FROM stg_dimcustomer;


		TRUNCATE TABLE stg_dimproduct 
 		BULK INSERT stg_dimproduct
		FROM 'C:\SQL_projects\global_Electronics_retailer\Products.csv'
		WITH (
			FORMAT = 'CSV',
			FIRSTROW = 2,
			FIELDTERMINATOR = ',',
			FIELDQUOTE = '"',
			TABLOCK
		);	
		TRUNCATE TABLE dimproduct
		INSERT INTO dimproduct (
			ProductKey,
			ProductName,
			Brand,
			Color,
			UnitCostUSD,
			UnitPriceUSD,
			SubcategoryKey,
			Subcategory,
			CategoryKey,
			Category
		)
		SELECT
			ProductKey,
			ProductName,
			Brand,
			Color,
			TRY_CONVERT(
				DECIMAL(10,3),
				REPLACE(REPLACE(TRIM(UnitCostUSD), '$', ''), ',', '')
			),
			TRY_CONVERT(
				DECIMAL(10,3),
				REPLACE(REPLACE(TRIM(UnitPriceUSD), '$', ''), ',', '')
			),
			SubcategoryKey,
			Subcategory,
			CategoryKey,
			Category
		FROM stg_dimproduct;



	END TRY
	BEGIN CATCH
		PRINT '================================================'
		PRINT 'ERROR OCCURED DURING LOADING TABLES
		PRINT 'Error Message' + ERROR_MESSAGE();
		PRINT 'Error Message' + CAST (ERROR_NUMBER() AS NVARCHAR);
		PRINT 'Error Message' + CAST (ERROR_STATE() AS NVARCHAR);
		PRINT '================================================'
	END CATCH
END
